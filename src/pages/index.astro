---
import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import PostList from '../components/PostList.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }: CollectionEntry<'posts'>) => !data.draft);
const posts = allPosts.sort((a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Philip Olivier">
  <Header />
  <main>
    <section class="bio">
      <p>[BIO PLACEHOLDER — paragraph one]</p>
      <p>[BIO PLACEHOLDER — paragraph two]</p>
      <p>[BIO PLACEHOLDER — paragraph three]</p>
    </section>
    <section class="posts">
      <PostList posts={posts} />
    </section>
  </main>
</Layout>

<style>
  .bio {
    margin-bottom: var(--spacing-xl);
  }

  .bio p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  .posts {
    margin-bottom: var(--spacing-xl);
  }
</style>
